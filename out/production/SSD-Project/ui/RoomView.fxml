<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<!--
    Room Management screen
    Section 1: View/filter all rooms (all roles can see this)
    Section 2: Update room rate (Manager only)
-->

<!-- VBox = vertical container -->
<VBox
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="ui.RoomController"
        spacing="14"
        style="-fx-padding: 30; -fx-background-color: #f0f4f8;">

    <!-- PAGE TITLE -->
    <Label
            text="Room Management"
            style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Separator/>

    <!-- SECTION 1: ROOM TABLE WITH STATUS FILTER -->

    <!-- HBox = horizontal row layout -->
    <HBox spacing="12" alignment="CENTER_LEFT">

        <Label text="Filter by Status:"
               style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

        <!-- Dropdown options are added in initialize() -->
        <ComboBox fx:id="statusFilterCombo" prefWidth="160"/>

        <!-- Calls handleApplyFilter() in controller -->
        <Button
                text="Apply Filter"
                onAction="#handleApplyFilter"
                style="-fx-background-color: #3498db; -fx-text-fill: white;
                   -fx-font-size: 13px; -fx-padding: 6 14 6 14;"/>

        <Button
                text="Show All Rooms"
                onAction="#handleShowAll"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                   -fx-font-size: 13px; -fx-padding: 6 14 6 14;"/>
    </HBox>

    <!-- Room table — data loaded by refreshTable() in controller -->
    <TableView fx:id="roomTable" prefHeight="280">
        <columns>
            <TableColumn fx:id="colRoomId"     text="Room ID"      prefWidth="70"/>
            <TableColumn fx:id="colRoomNumber" text="Room Number"  prefWidth="110"/>
            <TableColumn fx:id="colRoomType"   text="Type"         prefWidth="100"/>
            <TableColumn fx:id="colRate"       text="Rate / Night" prefWidth="110"/>
            <TableColumn fx:id="colStatus"     text="Status"       prefWidth="110"/>
            <TableColumn fx:id="colCleaning"   text="Cleaning"     prefWidth="110"/>
        </columns>
    </TableView>

    <Separator/>

    <!-- SECTION 2: UPDATE ROOM RATE (Manager Only) -->

    <Label text="Update Room Rate  —  Manager Only"
           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label
            text="Only the Manager role can update rates. All changes are audit logged."
            style="-fx-font-size: 11px; -fx-text-fill: #e67e22;"/>

    <!-- GridPane = grid layout with rows and columns -->
    <GridPane hgap="20" vgap="10">
        <padding><Insets top="4" bottom="4"/></padding>

        <!-- Row 0: Room ID input -->
        <Label text="Room ID:"
               GridPane.rowIndex="0" GridPane.columnIndex="0"
               style="-fx-font-size: 13px; -fx-font-weight: bold;"
               prefWidth="130"/>
        <TextField
                fx:id="rateRoomIdField"
                promptText="Enter room ID"
                prefWidth="180"
                GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <!-- Row 1: New Rate input -->
        <Label text="New Rate (per night):"
               GridPane.rowIndex="1" GridPane.columnIndex="0"
               style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
        <TextField
                fx:id="newRateField"
                promptText="e.g. 200.00"
                prefWidth="180"
                GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>

    <!-- Buttons — updateRateBtn is disabled for non-Managers in initialize() -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Button
                fx:id="updateRateBtn"
                text="Update Rate"
                onAction="#handleUpdateRate"
                prefWidth="140"
                style="-fx-background-color: #e67e22; -fx-text-fill: white;
                   -fx-font-size: 13px; -fx-font-weight: bold;
                   -fx-padding: 8 14 8 14;"/>

        <Button
                text="Clear"
                onAction="#handleClearRate"
                prefWidth="90"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                   -fx-font-size: 13px; -fx-padding: 8 14 8 14;"/>
    </HBox>

    <!-- Status message — green = success, red = error -->
    <Label
            fx:id="statusLabel"
            text=""
            style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

</VBox>
