<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- Booking management screen -->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.BookingController"
      spacing="12"
      prefWidth="450"
      prefHeight="550">

    <padding>
        <Insets top="20" right="30" bottom="20" left="30"/>
    </padding>

    <Label text="Create New Booking" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <Label text="Guest Name:" prefWidth="100"/>
        <TextField fx:id="guestNameField" promptText="Full name" prefWidth="250"/>
    </HBox>

    <HBox spacing="10">
        <Label text="Phone:" prefWidth="100"/>
        <TextField fx:id="guestPhoneField" promptText="Phone number" prefWidth="250"/>
    </HBox>

    <HBox spacing="10">
        <Label text="Room ID:" prefWidth="100"/>
        <TextField fx:id="roomIdField" promptText="Room ID" prefWidth="250"/>
    </HBox>

    <HBox spacing="10">
        <Label text="Check-In:" prefWidth="100"/>
        <TextField fx:id="checkInField" promptText="yyyy-MM-dd" prefWidth="250"/>
    </HBox>

    <HBox spacing="10">
        <Label text="Check-Out:" prefWidth="100"/>
        <TextField fx:id="checkOutField" promptText="yyyy-MM-dd" prefWidth="250"/>
    </HBox>

    <Button text="Create Booking" onAction="#handleCreate" prefWidth="160"/>

    <Separator/>

    <Label text="Search Bookings" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <TextField fx:id="searchField" promptText="Guest name or phone number" prefWidth="280"/>
        <Button text="Search" onAction="#handleSearch"/>
    </HBox>

    <!-- Shows search results -->
    <ListView fx:id="resultsList" prefHeight="150"/>

    <!-- Shows error or success messages -->
    <Label fx:id="messageLabel"/>

</VBox>
