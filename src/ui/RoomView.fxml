<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.RoomController"
      spacing="0">

    <!-- NAVIGATION BAR -->
    <HBox spacing="0" style="-fx-background-color: #2c3e50;">
        <!-- Manager buttons -->
        <Button fx:id="navStaff" text="Staff Accounts" onAction="#goToStaff"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 12 18 12 18;"/>
        <Button fx:id="navReviewRecords" text="Review Records" onAction="#goToReviewRecords"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 12 18 12 18;"/>
        <!-- Receptionist buttons -->
        <Button fx:id="navBookings" text="Bookings" onAction="#goToBooking"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 12 18 12 18;"/>
        <Button fx:id="navCheckInOut" text="Check-In/Out" onAction="#goToCheckInOut"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 12 18 12 18;"/>
        <Button fx:id="navPayment" text="Payment" onAction="#goToPayment"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 12 18 12 18;"/>
        <!-- Rooms is active -->
        <Button text="Rooms" onAction="#goToRooms"
                style="-fx-background-color: #1a252f; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 18 12 18;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Logout" onAction="#handleLogout"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 18 12 18;"/>
    </HBox>

    <!-- CONTENT -->
    <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: #f0f4f8;">
        <Label text="Room Management"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Separator/>

        <!-- Filter -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Filter by Status:" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="statusFilterCombo" prefWidth="160"/>
            <Button text="Apply Filter" onAction="#handleApplyFilter"
                    style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 12 6 12;"/>
            <Button text="Show All" onAction="#handleShowAll"
                    style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-padding: 6 12 6 12;"/>
        </HBox>

        <!-- Room Table -->
        <TableView fx:id="roomTable" prefHeight="280">
            <columns>
                <TableColumn fx:id="colRoomId"     text="ID"       prefWidth="50"/>
                <TableColumn fx:id="colRoomNumber" text="Room No."  prefWidth="90"/>
                <TableColumn fx:id="colRoomType"   text="Type"      prefWidth="120"/>
                <TableColumn fx:id="colRate"        text="Rate"      prefWidth="90"/>
                <TableColumn fx:id="colStatus"      text="Status"    prefWidth="110"/>
                <TableColumn fx:id="colCleaning"    text="Cleaning"  prefWidth="110"/>
            </columns>
        </TableView>

        <Separator/>

        <!-- Update Rate (Manager only) -->
        <Label text="Update Room Rate (Manager only)"
               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Room ID:" style="-fx-font-weight: bold;" prefWidth="80"/>
            <TextField fx:id="rateRoomIdField" promptText="Room ID" prefWidth="100"/>
            <Label text="New Rate:" style="-fx-font-weight: bold;" prefWidth="80"/>
            <TextField fx:id="newRateField" promptText="e.g. 250.00" prefWidth="120"/>
            <Button fx:id="updateRateBtn" text="Update Rate" onAction="#handleUpdateRate"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 12 6 12;"/>
            <Button text="Clear" onAction="#handleClearRate"
                    style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 6 12 6 12;"/>
        </HBox>

        <Label fx:id="statusLabel" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
    </VBox>
</VBox>
