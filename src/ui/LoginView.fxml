<?xml version="1.0" encoding="UTF-8"?>
<!--noora-->
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- Login screen — first screen shown when the app starts -->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.LoginController"
      spacing="15" alignment="CENTER"
      style="-fx-padding: 40; -fx-background-color: #f0f4f8;">

    <Label text="Hotel Management System"
           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label text="Please log in to continue"
           style="-fx-font-size: 13; -fx-text-fill: #7f8c8d;"/>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Username:" prefWidth="100"/>
        <TextField fx:id="usernameField" prefWidth="200" promptText="Enter username"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Password:" prefWidth="100"/>
        <PasswordField fx:id="passwordField" prefWidth="200" promptText="Enter password"/>
    </HBox>

    <Button text="Login"
            onAction="#handleLogin"
            prefWidth="150"
            style="-fx-background-color: #2c3e50; -fx-text-fill: white;
                   -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 8 14 8 14;"/>

    <!-- Status message — red for error, green for success -->
    <Label fx:id="messageLabel" text=""/>

</VBox>
