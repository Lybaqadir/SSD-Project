<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.BookingController"
      spacing="0">

    <!-- NAVIGATION BAR -->
    <HBox spacing="0" style="-fx-background-color: #2c3e50;">
        <Button fx:id="navBookings" text="Bookings" onAction="#goToBooking"
                style="-fx-background-color: #1a252f; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 18 12 18;"/>
        <Button fx:id="navCheckInOut" text="Check-In/Out" onAction="#goToCheckInOut"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 12 18 12 18;"/>
        <Button fx:id="navPayment" text="Payment" onAction="#goToPayment"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 12 18 12 18;"/>
        <Button fx:id="navRooms" text="Rooms" onAction="#goToRooms"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 12 18 12 18;"/>
        <Button fx:id="navStaff" text="Staff Accounts" onAction="#goToStaff"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 12 18 12 18;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Logout" onAction="#handleLogout"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 18 12 18;"/>
    </HBox>

    <!-- CONTENT -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: #f0f4f8;">
        <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: #f0f4f8;">

            <!-- CREATE BOOKING -->
            <Label text="Create New Booking"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Separator/>

            <GridPane hgap="14" vgap="10">
                <Label text="Guest Name:"   GridPane.rowIndex="0" GridPane.columnIndex="0" prefWidth="110" style="-fx-font-weight: bold;"/>
                <TextField fx:id="guestNameField"  promptText="Full name"       prefWidth="250" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Phone:"        GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="guestPhoneField" promptText="Phone number"    prefWidth="250" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Room ID:"      GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="roomIdField"     promptText="Room ID"         prefWidth="250" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Check-In:"     GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="checkInField"    promptText="yyyy-MM-dd"      prefWidth="250" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="Check-Out:"    GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="checkOutField"   promptText="yyyy-MM-dd"      prefWidth="250" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
            </GridPane>

            <Button text="Create Booking" onAction="#handleCreate" prefWidth="160"
                    style="-fx-background-color: #2980b9; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 8 14 8 14;"/>

            <Separator/>

            <!-- MODIFY BOOKING (N004) -->
            <Label text="Modify Booking"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Update the dates of an existing booking."
                   style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
            <Separator/>

            <GridPane hgap="14" vgap="10">
                <Label text="Booking ID:"   GridPane.rowIndex="0" GridPane.columnIndex="0" prefWidth="110" style="-fx-font-weight: bold;"/>
                <TextField fx:id="modifyBookingIdField" promptText="Booking ID to modify" prefWidth="250" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="New Check-In:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="modifyCheckInField"   promptText="yyyy-MM-dd"           prefWidth="250" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="New Check-Out:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="modifyCheckOutField"  promptText="yyyy-MM-dd"           prefWidth="250" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>

            <Button text="Modify Booking" onAction="#handleModify" prefWidth="160"
                    style="-fx-background-color: #8e44ad; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 8 14 8 14;"/>

            <Separator/>

            <!-- SEARCH BOOKINGS -->
            <Label text="Search Bookings"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Guest name or phone number" prefWidth="280"/>
                <Button text="Search" onAction="#handleSearch"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 14 8 14;"/>
            </HBox>

            <ListView fx:id="resultsList" prefHeight="140"/>
            <Label fx:id="messageLabel" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

        </VBox>
    </ScrollPane>
</VBox>
