<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.CheckInOutController"
      spacing="0">

    <!-- NAVIGATION BAR -->
    <HBox spacing="0" style="-fx-background-color: #2c3e50;">
        <Button fx:id="navBookings" text="Bookings" onAction="#goToBooking"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 12 18 12 18;"/>
        <Button fx:id="navCheckInOut" text="Check-In/Out" onAction="#goToCheckInOut"
                style="-fx-background-color: #1a252f; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 18 12 18;"/>
        <Button fx:id="navPayment" text="Payment" onAction="#goToPayment"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 12 18 12 18;"/>
        <Button fx:id="navRooms" text="Rooms" onAction="#goToRooms"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 12 18 12 18;"/>
        <Button fx:id="navStaff" text="Staff Accounts" onAction="#goToStaff"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 12 18 12 18;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Logout" onAction="#handleLogout"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 18 12 18;"/>
    </HBox>

    <!-- CONTENT -->
    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f0f4f8;">

        <!-- CHECK IN / CHECK OUT SECTION -->
        <Label text="Guest Check-In / Check-Out"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Separator/>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Booking ID:" prefWidth="120"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <TextField fx:id="bookingIdField" promptText="Enter booking ID" prefWidth="200"/>
        </HBox>

        <HBox spacing="20" alignment="CENTER_LEFT">
            <Button text="Check-In" onAction="#handleCheckIn" prefWidth="130"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 10 20 10 20;"/>
            <Button text="Check-Out" onAction="#handleCheckOut" prefWidth="130"
                    style="-fx-background-color: #e67e22; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 10 20 10 20;"/>
        </HBox>

        <Label fx:id="messageLabel" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

        <Separator/>

        <!-- MARK ROOM AS DIRTY SECTION (Receptionist only) -->
        <Label text="Mark Room as Dirty"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #c0392b;"/>
        <Label text="Use this after a guest checks out so Cleaning Staff know which rooms to clean."
               style="-fx-font-size: 12px; -fx-text-fill: #888;"/>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Room ID:" prefWidth="120"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <TextField fx:id="roomIdDirtyField" promptText="Enter room ID to mark dirty" prefWidth="200"/>
            <Button text="Mark as Dirty" onAction="#handleMarkDirty" prefWidth="140"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 8 14 8 14;"/>
        </HBox>

    </VBox>
</VBox>
